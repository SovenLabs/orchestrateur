/target/
**/*.rs.bk
.idea/
.vscode/
*.pdb

# Outils de build locaux (PROTOC vendored — voir .cargo/config.toml)
.tools/

# Workspace parasite si lancé depuis la racine du repo (cwd incorrect)
/memories/

# Workspace runtime (données locales)
workspace/.vector/**
!workspace/.vector/.gitkeep
workspace/memories/*.md
workspace/logs/*.log
workspace/config/orchestrator.toml

# LanceDB local (généré au premier run)
workspace/.orchestrateur/**
!workspace/.orchestrateur/.gitkeep