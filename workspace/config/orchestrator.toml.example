[workspace]
path = "./memories"

[backlinks]
semantic_min = 0.75
max_links = 10

[providers]
primary_llm = "xai"
fallback_llm = ["ollama"]
primary_embedding = "ollama"
fallback_embedding = []

[xai]
api_key_env = "XAI_API_KEY"
model = "grok-3-latest"
timeout_secs = 30
max_retries = 2

[ollama]
url = "http://127.0.0.1:11434"
embedding_model = "qwen3-embedding:8b"
chat_model = "qwen3:8b"
timeout_secs = 60
max_retries = 2

[vector_store]
type = "lancedb"
path = ".orchestrateur/lancedb"
embedding_dimension = 768

[lancedb]
path = ".orchestrateur/lancedb"
embedding_dimension = 768