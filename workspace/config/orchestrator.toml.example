[workspace]
path = "./memories"

[backlinks]
semantic_min = 0.75
max_links = 10

[providers]
primary_llm = "ollama"
fallback_llm = ["ollama"]
primary_embedding = "ollama"
fallback_embedding = []

[xai]
api_key_env = "XAI_API_KEY"
model = "grok-4.3"
timeout_secs = 30
max_retries = 2

[ollama]
url = "http://127.0.0.1:11434"
embedding_model = "qwen3-embedding:8b"
chat_model = "qwen3:8b"
timeout_secs = 60
max_retries = 2

[vector_store]
type = "lancedb"
path = ".orchestrateur/lancedb"
embedding_dimension = 768

# Défense en profondeur — profils : default | ai_assisted | strict | expert | local_only
# Pour travailler intensivement avec l'IA : profile = "ai_assisted"
# Zéro egress cloud (LLM/embeddings locaux + scan secrets) : profile = "local_only"
[security]
profile = "ai_assisted"
enabled = true
max_content_length = 64000
max_title_length = 512
max_tags = 32
max_backlinks = 20
detect_injection_patterns = true
# Surcharges egress (prioritaires sur le profil si définies) :
# block_cloud_llm = true
# scan_secrets_before_llm = true

# Surcharges optionnelles (prioritaires sur le profil) :
# [security.behavioral]
# max_assimilations_per_minute = 500

[security.integrity]
enabled = true
verify_config_hash = true
bootstrap_on_missing = true
require_manifest = false
seed_honeypots = false
honeypot_count = 3

[security.audit]
enabled = true
path = "logs/audit.jsonl"

# Agents persistants Phase 2b — worker tick, délégations, cron
[agents]
enabled = true
tick_interval_secs = 60
auto_turn_on_inbox = false
default_worker_id = "default"

# Daemon WebSocket local — Territoire Graphique (orchestrateur daemon run)
[daemon]
enabled = true
bind = "127.0.0.1"
port = 28790
token_env = "ORCHESTRATEUR_DAEMON_TOKEN"

# Gateway WebSocket Phase 8 — canaux messaging (orchestrateur gateway run)
[gateway]
enabled = true
bind = "127.0.0.1"
port = 28789
token_env = "ORCHESTRATEUR_GATEWAY_TOKEN"

[gateway.webhook]
enabled = true
token_env = "ORCHESTRATEUR_WEBHOOK_SECRET"

[gateway.telegram]
enabled = true
token_env = "TELEGRAM_BOT_TOKEN"

[gateway.discord]
enabled = false
token_env = "DISCORD_BOT_TOKEN"
# Livraison sortante optionnelle : DISCORD_WEBHOOK_URL

[gateway.slack]
enabled = false
token_env = "SLACK_BOT_TOKEN"
# Livraison sortante : SLACK_CHANNEL_ID ou external_id dans le webhook

# Provider registry Phase 9 — 12 LLM + 5 embeddings
# orchestrateur providers list

[provider_profiles.openai]
model = "gpt-4o"
api_key_env = "OPENAI_API_KEY"

[provider_profiles.groq]
model = "llama-3.3-70b-versatile"
api_key_env = "GROQ_API_KEY"

[provider_profiles.openrouter]
model = "openai/gpt-4o"
api_key_env = "OPENROUTER_API_KEY"

# MCP client Phase 9 (stdio)
[mcp]
enabled = false

# [[mcp.servers]]
# name = "filesystem"
# command = "npx"
# args = ["-y", "@modelcontextprotocol/server-filesystem", "."]

# Agent Phase 10 — profils de capacités + auto-assimilation systématique
[agent]
active_capability_profile = "agent"
auto_assimilate_turn = true
max_tool_iterations = 3
graph_context_enabled = true
graph_hub_limit = 5
proactive_memory_search = true
proactive_search_limit = 5
max_history_turns = 20
skill_tools_enabled = true
skill_auto_suggest = true
# Phase 14 — auto-exécution skill si score suggestion ≥ seuil
skill_auto_execute = false
skill_auto_execute_threshold = 10
# v1.2 — prétraitement bidirectionnel (expand court / compress long)
message_preprocess = true
enrichment_min_chars = 40
compression_max_chars = 8000
compression_max_attachment_mb = 2
compression_preserve_entities = true

# Watcher session — génère des drafts depuis les fichiers Markdown surveillés
[watcher]
enabled = true
debounce_secs = 8
watch_dirs = [".orchestrateur/sessions"]

# Canaux additionnels Phase 10 (stubs — polling HTTP Phase 14)
# orchestrateur channels list

[gateway.channels.whatsapp]
enabled = false
token_env = "WHATSAPP_TOKEN"
# poll_url = "http://127.0.0.1:8080/whatsapp/poll"
# poll_interval_secs = 30

[gateway.channels.signal]
enabled = false
token_env = "SIGNAL_CLI_TOKEN"

[gateway.channels.matrix]
enabled = false
token_env = "MATRIX_ACCESS_TOKEN"

[gateway.channels.teams]
enabled = false
token_env = "TEAMS_BOT_TOKEN"

[gateway.channels.email]
enabled = false
token_env = "EMAIL_IMAP_PASSWORD"

[gateway.channels.irc]
enabled = false
token_env = "IRC_NICKSERV_PASSWORD"

[gateway.channels.google_chat]
enabled = false
token_env = "GOOGLE_CHAT_TOKEN"

[gateway.channels.line]
enabled = false
token_env = "LINE_CHANNEL_TOKEN"

[gateway.channels.mattermost]
enabled = false
token_env = "MATTERMOST_TOKEN"

[gateway.channels.rocketchat]
enabled = false
token_env = "ROCKETCHAT_TOKEN"

[gateway.channels.bluesky]
enabled = false
token_env = "BLUESKY_APP_PASSWORD"

[gateway.channels.nostr]
enabled = false
token_env = "NOSTR_PRIVATE_KEY"

[gateway.channels.twitch]
enabled = false
token_env = "TWITCH_BOT_TOKEN"

# Skills hub Phase 11 — plugins dynamiques (subprocess)
# orchestrateur skills-hub list
# orchestrateur skills-hub path

[skills_hub]
enabled = true
directory = "skills"
auto_load = true
marketplace_enabled = true
marketplace_catalog = "skills/marketplace/catalog.json"
# marketplace_url = "https://example.com/skills/catalog.json"
# marketplace_require_signature = false

# [[skills_hub.entries]]
# id = "inline-echo"
# description = "Echo inline depuis TOML"
# command = "echo"
# args = ["inline"]
# enabled = false
# stdin_json = false
# timeout_secs = 10

# Test E2E Ollama (optionnel, marqué #[ignore] par défaut) :
#   cargo test -p infrastructure ollama_end_to_end_when_available -- --ignored
# Prérequis : ollama serve + modèles embedding_model et chat_model tirés.